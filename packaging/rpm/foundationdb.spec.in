Name: foundationdb
Version: FDBVERSION
Release: FDBRELEASE
Group: Applications/Databases
License: Apache Software License 2.0
URL: https://www.foundationdb.org
Packager: FoundationDB <fdb-dist@apple.com>
BuildArch: x86_64
Summary: Ordered key-value store with full ACID transactions
Vendor: FoundationDB

# Define version directory and priority for update-alternatives
%global versiondir foundationdb-%{version}
%global priority %(echo %{version} | tr -d '.' | sed 's/-//g')

%description
FoundationDB is a scalable, fault-tolerant, ordered key-value store
with full ACID transactions.

%package server
Summary: FoundationDB server
Requires: foundationdb-clients = %{version}-%{release}
Conflicts: foundationdb < 0.1.4

Requires(pre): /usr/sbin/useradd, /usr/sbin/groupadd, /usr/bin/getent
# This is a heavy hammer, to remove /usr/bin/python as a dependency,
# as it also removes dependencies like glibc. However, none of the
# other strategies (__requires_exclude) seem to work.
AutoReq: 0

%package clients
Summary: FoundationDB clients and library
Conflicts: foundationdb < 0.1.4
Requires(pre): /usr/sbin/useradd, /usr/sbin/groupadd, /usr/bin/getent

%description server
FoundationDB is a scalable, fault-tolerant, ordered key-value store
with full ACID transactions.

This package contains the server.

%description clients
FoundationDB is a scalable, fault-tolerant, ordered key-value store
with full ACID transactions.

This package contains client utilities and libraries.

%prep
rm -rf %{buildroot}
mkdir -p %{buildroot}
tar -xzf %{_sourcedir}/install-files.tar.gz -C %{buildroot}
rm -r %{buildroot}/etc/rc.d

%pre server
# This should be ensured by the foundationdb-clients package, but it can't hurt...
getent group foundationdb >/dev/null || groupadd -r foundationdb >/dev/null
getent passwd foundationdb >/dev/null || useradd -c "FoundationDB" -g foundationdb -s /bin/false -r -d /var/lib/foundationdb foundationdb >/dev/null

if [ $1 -gt 1 ]; then
    # old versions could leave this behind
    rm -f /usr/lib/foundationdb/argparse.py /usr/lib/foundationdb/argparse.pyc
fi

CURRENTVER=$(rpm -q --queryformat %%{VERSION} foundationdb-server) || :
if [ "$CURRENTVER" = "0.1.5" ] || [ "$CURRENTVER" = "0.1.4" ]; then
    mv /etc/foundationdb/foundationdb.conf /etc/foundationdb/foundationdb.conf.rpmsave
fi
exit 0

%post server
if [ $1 -eq 1 ]; then
    # First installation
    if [ ! -f /etc/foundationdb/fdb.cluster ]; then
        description=$(LC_CTYPE=C tr -dc A-Za-z0-9 < /dev/urandom | head -c 8)
        random_str=$(LC_CTYPE=C tr -dc A-Za-z0-9 < /dev/urandom | head -c 8)
        echo $description:$random_str@127.0.0.1:4500 > /etc/foundationdb/fdb.cluster
        chown foundationdb:foundationdb /etc/foundationdb/fdb.cluster
        chmod 0664 /etc/foundationdb/fdb.cluster
        NEWDB=1
    fi
    
    # Copy config if not exists
    if [ ! -f /etc/foundationdb/foundationdb.conf ]; then
        cp /usr/lib/%{versiondir}/etc/foundationdb/foundationdb.conf /etc/foundationdb/
        chown foundationdb:foundationdb /etc/foundationdb/foundationdb.conf
    fi
fi

# Set up alternatives for server binaries
update-alternatives --install /usr/sbin/fdbserver fdbserver \
    /usr/lib/%{versiondir}/sbin/fdbserver %{priority} \
    --slave /usr/sbin/fdbmonitor fdbmonitor /usr/lib/%{versiondir}/sbin/fdbmonitor \
    --slave /lib/systemd/system/foundationdb.service foundationdb.service /usr/lib/%{versiondir}/lib/systemd/system/foundationdb.service

if [ $1 -eq 1 ]; then
    # First installation - start service
    /usr/bin/systemctl daemon-reload > /dev/null 2>&1
    /usr/bin/systemctl enable foundationdb > /dev/null 2>&1
    /usr/bin/systemctl start foundationdb > /dev/null 2>&1
    
    if [ "$NEWDB" != "" ]; then
        /usr/bin/fdbcli -C /etc/foundationdb/fdb.cluster --exec "configure new single memory" --timeout 20 > /dev/null 2>&1
    fi
else
    # Upgrade - restart service
    /usr/bin/systemctl daemon-reload > /dev/null 2>&1
    /usr/bin/systemctl condrestart foundationdb > /dev/null 2>&1
fi
exit 0

%preun server
if [ $1 -eq 0 ]; then
    # Complete uninstall - remove alternatives
    /usr/bin/systemctl stop foundationdb > /dev/null 2>&1
    /usr/bin/systemctl disable foundationdb > /dev/null 2>&1
    update-alternatives --remove fdbserver /usr/lib/%{versiondir}/sbin/fdbserver
fi
exit 0

%pre clients
getent group foundationdb >/dev/null || groupadd -r foundationdb >/dev/null
getent passwd foundationdb >/dev/null || useradd -c "FoundationDB" -g foundationdb -s /bin/false -r -d /var/lib/foundationdb foundationdb >/dev/null
exit 0

%post clients
# Remove old python artifacts
rm -rf /usr/lib64/python2.6/fdb

# Set up alternatives for multi-version support
update-alternatives --install /usr/bin/fdbcli fdbcli \
    /usr/lib/%{versiondir}/bin/fdbcli %{priority} \
    --slave /usr/bin/fdbbackup fdbbackup /usr/lib/%{versiondir}/bin/fdbbackup \
    --slave /usr/bin/fdbrestore fdbrestore /usr/lib/%{versiondir}/bin/fdbbackup \
    --slave /usr/bin/fdbdr fdbdr /usr/lib/%{versiondir}/bin/fdbbackup \
    --slave /usr/bin/dr_agent dr_agent /usr/lib/%{versiondir}/bin/fdbbackup \
    --slave /usr/bin/backup_agent backup_agent /usr/lib/%{versiondir}/bin/fdbbackup \
    --slave /usr/lib64/libfdb_c.so libfdb_c.so /usr/lib/%{versiondir}/lib/libfdb_c.so \
    --slave /usr/lib64/libfdb_c_shim.so libfdb_c_shim.so /usr/lib/%{versiondir}/lib/libfdb_c_shim.so \
    --slave /usr/include/foundationdb fdb_headers /usr/lib/%{versiondir}/include/foundationdb

exit 0

%preun clients
if [ $1 -eq 0 ]; then
    # Only remove alternatives on complete uninstall, not upgrade
    update-alternatives --remove fdbcli /usr/lib/%{versiondir}/bin/fdbcli
fi
exit 0

%files server
%defattr(-,root,root)
%doc /usr/share/doc/foundationdb-server
%attr(0700,foundationdb,foundationdb) /var/lib/foundationdb
%attr(0700,foundationdb,foundationdb) /var/log/foundationdb
%attr(0775,foundationdb,foundationdb) %dir /etc/foundationdb
/usr/lib/%{versiondir}/sbin/fdbserver
/usr/lib/%{versiondir}/sbin/fdbmonitor
/usr/lib/%{versiondir}/lib/systemd/system/foundationdb.service
/usr/lib/%{versiondir}/etc/foundationdb/foundationdb.conf
/usr/lib/%{versiondir}/lib/make_public.py

%files clients
%defattr(-,root,root)
%doc /usr/share/doc/foundationdb-clients
/usr/lib/%{versiondir}/bin/fdbcli
/usr/lib/%{versiondir}/bin/fdbbackup
/usr/lib/%{versiondir}/lib/libfdb_c.so
/usr/lib/%{versiondir}/lib/libfdb_c_shim.so
/usr/lib/%{versiondir}/include/foundationdb/*
